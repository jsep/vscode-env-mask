{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "dotenv",
  "scopeName": "source.envmask.dotenv",
  "patterns": [
    { "include": "#comment" },
    { "include": "#env-line" }
  ],
  "repository": {
    "comment": {
      "match": "\\s#.*$",
      "name": "comment.line.number-sign.envmask"
    },
    "env-line": {
      "match": "^(\\s*(?:export\\s+)?)([A-Za-z_][A-Za-z0-9_]*)(=)(.*)$",
      "captures": {
        "1": { "name": "keyword.other.export.envmask" },
        "2": { "name": "variable.other.envmask.key" },
        "3": { "name": "punctuation.separator.key-value.envmask" },
        "4": { "name": "variable.other.envmask.value" }
      }
    }
  }
}
